# ─────────────────────────────────────────────
# INDUCTA Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# JWT Secret (generate a long random string — e.g. openssl rand -hex 64)
JWT_SECRET=your_secret_key_here

# ─── Firebase ───────────────────────────────
# Download from Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY_ID=your_firebase_private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour Firebase Private Key\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your_firebase_client_id
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# ─── Razorpay ───────────────────────────────
# Get from Razorpay Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ─── Email (Nodemailer) ─────────────────────
# Use Gmail App Password or any SMTP provider
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=INDUCTA <noreply@inducta.in>

# ─── Frontend URL (for CORS) ────────────────
FRONTEND_URL=http://localhost:3000
